# SENTINEL — .gitignore

# === Secrets ===
.env

# === Python ===
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# === Virtual environment ===
venv/
.venv/

# === Data ===
data/sentinel.db
data/sentinel.db-wal
data/sentinel.db-shm
data/backups/
data/state.json
data/heartbeat
# Ad-hoc DB backups left by migrations / one-off recovery scripts.
# N-4 audit fix: files like sentinel.db.bak_before_ml_fix (+ -wal / -shm)
# aren't caught by the *.db rule in the root .gitignore because their
# extension is .bak_*, not .db. Pattern matches all .bak variants.
data/*.bak*

# === Logs ===
logs/*.log
logs/*.jsonl

# === ML model backups ===
data/ml_models/backup_*/

# === PID ===
sentinel.pid

# === IDE ===
.vscode/
.idea/
*.swp
*.swo

# === OS ===
Thumbs.db
.DS_Store
